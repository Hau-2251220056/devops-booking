// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// ENUMS
// ============================================================================

enum UserRole {
  admin
  staff
  customer
}

enum BookingStatus {
  pending
  confirmed
  cancelled
  completed
}

enum PaymentMethod {
  cash
  card
  bank_transfer
  e_wallet
}

enum PaymentStatus {
  pending
  completed
  failed
  refunded
}

enum AuditAction {
  create
  update
  delete
  cancel
}

// ============================================================================
// MODELS
// ============================================================================

model Branch {
  id            String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name          String    @db.VarChar(255)
  address       String
  phone         String    @db.VarChar(20)
  email         String?   @db.VarChar(255)
  city          String?   @db.VarChar(100)
  district      String?   @db.VarChar(100)
  openingTime   DateTime  @default(dbgenerated("'08:00:00'::time")) @map("opening_time") @db.Time()
  closingTime   DateTime  @default(dbgenerated("'18:00:00'::time")) @map("closing_time") @db.Time()
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamp(6)
  deletedAt     DateTime? @map("deleted_at") @db.Timestamp(6)

  barbers       Barber[]
  services      Service[]
  timeSlots     TimeSlot[]
  workingHours  WorkingHour[]
  bookings      Booking[]

  @@index([city])
  @@index([isActive])
  @@map("branches")
}

model User {
  id                   String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  username             String    @unique @db.VarChar(100)
  email                String    @unique @db.VarChar(255)
  passwordHash         String    @map("password_hash") @db.VarChar(255)
  firstName            String?   @map("first_name") @db.VarChar(100)
  lastName             String?   @map("last_name") @db.VarChar(100)
  phone                String?   @db.VarChar(20)
  avatarUrl            String?   @map("avatar_url")
  role                 UserRole  @default(customer)
  isActive             Boolean   @default(true) @map("is_active")
  isVerified           Boolean   @default(false) @map("is_verified")
  verifyToken          String?   @map("verify_token") @db.VarChar(255)
  verifyTokenExpiresAt DateTime? @map("verify_token_expires_at") @db.Timestamp(6)
  resetToken           String?   @map("reset_token") @db.VarChar(255)
  resetTokenExpiresAt  DateTime? @map("reset_token_expires_at") @db.Timestamp(6)
  lastLoginAt          DateTime? @map("last_login_at") @db.Timestamp(6)
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt            DateTime  @updatedAt @map("updated_at") @db.Timestamp(6)
  deletedAt            DateTime? @map("deleted_at") @db.Timestamp(6)

  barber              Barber?
  bookings            Booking[]          @relation("customer")
  cancelledBookings   Booking[]          @relation("cancelled_by")
  reviews             Review[]
  auditLogs           AuditLog[]

  @@index([role])
  @@index([isActive])
  @@map("users")
}

model Barber {
  id                String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  branchId          String    @map("branch_id") @db.Uuid
  userId            String    @unique @map("user_id") @db.Uuid
  specialization    String?   @db.VarChar(255)
  experienceYears   Int?      @map("experience_years")
  rating            Decimal   @default(5.0) @db.Decimal(3, 2)
  totalBookings     Int       @default(0) @map("total_bookings")
  bio               String?
  avatarUrl         String?   @map("avatar_url")
  isActive          Boolean   @default(true) @map("is_active")
  isAvailable       Boolean   @default(true) @map("is_available")
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamp(6)
  deletedAt         DateTime? @map("deleted_at") @db.Timestamp(6)

  branch   Branch   @relation(fields: [branchId], references: [id], onDelete: Restrict)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings Booking[]
  reviews  Review[]

  @@index([branchId])
  @@index([isActive])
  @@index([isAvailable])
  @@map("barbers")
}

model Service {
  id            String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  branchId      String    @map("branch_id") @db.Uuid
  name          String    @db.VarChar(255)
  description   String?
  price         Decimal   @db.Decimal(10, 2)
  durationMinutes Int     @map("duration_minutes")
  category      String?   @db.VarChar(100)
  imageUrl      String?   @map("image_url")
  isActive      Boolean   @default(true) @map("is_active")
  orderIndex    Int       @default(0) @map("order_index")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamp(6)
  deletedAt     DateTime? @map("deleted_at") @db.Timestamp(6)

  branch           Branch              @relation(fields: [branchId], references: [id], onDelete: Cascade)
  bookingServices  BookingService[]

  @@index([branchId])
  @@index([isActive])
  @@index([category])
  @@map("services")
}

model TimeSlot {
  id              String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  branchId        String    @map("branch_id") @db.Uuid
  startTime       DateTime  @map("start_time") @db.Time()
  endTime         DateTime  @map("end_time") @db.Time()
  durationMinutes Int       @map("duration_minutes")
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamp(6)

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([branchId, startTime, endTime])
  @@index([branchId])
  @@index([startTime])
  @@map("time_slots")
}

model WorkingHour {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  branchId    String    @map("branch_id") @db.Uuid
  dayOfWeek   Int       @map("day_of_week")
  startTime   DateTime  @map("start_time") @db.Time()
  endTime     DateTime  @map("end_time") @db.Time()
  isOpen      Boolean   @default(true) @map("is_open")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamp(6)

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([branchId, dayOfWeek])
  @@index([branchId])
  @@index([dayOfWeek])
  @@map("working_hours")
}

model Booking {
  id                String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  customerId        String        @map("customer_id") @db.Uuid
  barberId          String        @map("barber_id") @db.Uuid
  branchId          String        @map("branch_id") @db.Uuid
  bookingDate       DateTime      @map("booking_date") @db.Date
  startTime         DateTime      @map("start_time") @db.Time()
  endTime           DateTime      @map("end_time") @db.Time()
  totalAmount       Decimal       @default(0) @map("total_amount") @db.Decimal(10, 2)
  notes             String?
  status            BookingStatus @default(pending)
  cancellationReason String?      @map("cancellation_reason")
  cancelledAt       DateTime?     @map("cancelled_at") @db.Timestamp(6)
  cancelledBy       String?       @map("cancelled_by") @db.Uuid
  completedAt       DateTime?     @map("completed_at") @db.Timestamp(6)
  createdAt         DateTime      @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt         DateTime      @updatedAt @map("updated_at") @db.Timestamp(6)
  deletedAt         DateTime?     @map("deleted_at") @db.Timestamp(6)

  customer          User             @relation("customer", fields: [customerId], references: [id], onDelete: Restrict)
  barber            Barber           @relation(fields: [barberId], references: [id], onDelete: Restrict)
  branch            Branch           @relation(fields: [branchId], references: [id], onDelete: Restrict)
  cancelledByUser   User?            @relation("cancelled_by", fields: [cancelledBy], references: [id], onDelete: SetNull)
  bookingServices   BookingService[]
  review            Review?
  payments          Payment[]

  @@unique([barberId, bookingDate, startTime, endTime], name: "unique_barber_time_slot")
  @@index([customerId])
  @@index([barberId])
  @@index([branchId])
  @@index([bookingDate])
  @@index([status])
  @@map("bookings")
}

model BookingService {
  id        String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  bookingId String    @map("booking_id") @db.Uuid
  serviceId String    @map("service_id") @db.Uuid
  quantity  Int       @default(1)
  unitPrice Decimal   @map("unit_price") @db.Decimal(10, 2)
  subtotal  Decimal   @db.Decimal(10, 2)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamp(6)

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  @@index([bookingId])
  @@index([serviceId])
  @@map("booking_services")
}

model Review {
  id        String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  bookingId String    @unique @map("booking_id") @db.Uuid
  customerId String   @map("customer_id") @db.Uuid
  barberId  String    @map("barber_id") @db.Uuid
  rating    Int
  comment   String?
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamp(6)

  booking  Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  customer User    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  barber   Barber  @relation(fields: [barberId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([customerId])
  @@index([barberId])
  @@index([rating])
  @@map("reviews")
}

model Payment {
  id            String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  bookingId     String        @map("booking_id") @db.Uuid
  amount        Decimal       @db.Decimal(10, 2)
  paymentMethod PaymentMethod @map("payment_method")
  paymentStatus PaymentStatus @default(pending) @map("payment_status")
  transactionId String?       @map("transaction_id") @db.VarChar(255)
  paidAt        DateTime?     @map("paid_at") @db.Timestamp(6)
  refundedAt    DateTime?     @map("refunded_at") @db.Timestamp(6)
  notes         String?
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt     DateTime      @updatedAt @map("updated_at") @db.Timestamp(6)

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([paymentStatus])
  @@index([paidAt])
  @@map("payments")
}

model AuditLog {
  id         String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId     String?     @map("user_id") @db.Uuid
  entityType String      @map("entity_type") @db.VarChar(100)
  entityId   String      @map("entity_id") @db.Uuid
  action     AuditAction
  oldValues  Json?       @map("old_values")
  newValues  Json?       @map("new_values")
  ipAddress  String?     @map("ip_address") @db.VarChar(50)
  userAgent  String?     @map("user_agent")
  createdAt  DateTime    @default(now()) @map("created_at") @db.Timestamp(6)

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
  @@index([action])
  @@map("audit_logs")
}
